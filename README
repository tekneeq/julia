# Default: ±5% around spot, auto-opens the PNG on macOS
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14

# Wider view
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --range 10

# Whole chain
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --range 0

# Don't auto-open
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --no-open

# Custom path
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --out ~/Desktop/spy-oi.png

# Cumulative view
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --cumulative

# Bar view (default, unchanged)
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14

# Wider range on the cumulative
UV_NATIVE_TLS=true uv run lia oi-value --ticker SPY --expiration 2026-07-14 --cumulative --range 10

